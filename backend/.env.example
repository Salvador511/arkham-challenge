# ============================================================
# Nuclear Outages API - Environment Variables Example
# Copy this file to .env and replace placeholder values.
# ============================================================

# Required: EIA API key used by connector/extract_data.py
EIA_API_KEY=your_eia_api_key_here

# Optional: If set, app uses PostgreSQL-backed storage.
# If empty or omitted, app falls back to local filesystem (storage/).
DATABASE_URL=postgresql://user:password@host:5432/database
